# ==================== DJANGO ====================
SECRET_KEY=your-super-secret-key-change-this-in-production-min-50-chars
DEBUG=False
ENVIRONMENT=production
DJANGO_SETTINGS_MODULE=flirty_backend.settings_prod

# ==================== DATABASE ====================
# IMPORTANT: Use strong password (min 32 chars with special characters)
DB_PASSWORD=your_super_secure_db_password_32_chars_minimum_with_special_chars

# ==================== REDIS ====================
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=your_redis_password_optional

# ==================== CELERY ====================
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ==================== OPENAI ====================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE_BASE=0.85
OPENAI_MAX_RETRIES=3
OPENAI_REQUEST_TIMEOUT=30

# ==================== SECURITY ====================
# CORS settings - restrict to your frontend domain
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ==================== SENTRY (Error Tracking) ====================
SENTRY_DSN=https://your-sentry-dsn-here@sentry.io/your-project-id

# ==================== MONITORING ====================
GRAFANA_PASSWORD=your_grafana_admin_password
PROMETHEUS_PASSWORD=optional_prometheus_password

# ==================== RATE LIMITING ====================
# Per-user limits
UPLOAD_RATE_LIMIT_PER_MINUTE=1
RETRIEVAL_RATE_LIMIT_PER_MINUTE=10
API_RATE_LIMIT_PER_HOUR=1000

# ==================== RESPONSE SETTINGS ====================
RESPONSE_MIN_CHARS=140
RESPONSE_MAX_CHARS=180
MAX_REPHRASE_ATTEMPTS=3

# ==================== SIMILARITY THRESHOLDS ====================
# Very strict thresholds for production
SEMANTIC_SIMILARITY_THRESHOLD=0.95
LEXICAL_SIMILARITY_THRESHOLD=0.95

# ==================== LOGGING ====================
LOG_LEVEL=INFO
LOG_FILE_PATH=/var/log/django/flirty.log

# ==================== CACHE ====================
CACHE_TIMEOUT_DEFAULT=300
CACHE_TIMEOUT_AI_RESPONSE=3600
CACHE_TIMEOUT_USER_DATA=600

# ==================== EMAIL (if needed) ====================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password

# ==================== AWS (if using for media storage) ====================
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1

# ==================== DEPLOYMENT SPECIFIC ====================
# Used by Docker Compose
INSTANCE_ID=backend-1
WORKERS=8
THREADS=2
